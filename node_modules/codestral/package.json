{
  "name": "codestral",
  "version": "1.1.1",
  "description": "AI-powered terminal coding assistant using Mistral AI",
  "main": "src/index.js",
  "bin": {
    "codestral": "bin/codestral.js"
  },
  "scripts": {
    "start": "node bin/codestral.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "dev": "node --watch bin/codestral.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai",
    "assistant",
    "terminal",
    "cli",
    "mistral",
    "coding"
  ],
  "author": "Akanmu Akinkunmi Joseph (PetrJoe)",
  "license": "MIT",
  "dependencies": {
    "@mistralai/mistralai": "^1.10.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "cli-highlight": "^2.1.11",
    "cosmiconfig": "^9.0.0",
    "diff": "^8.0.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "open": "^10.0.3",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PetrJoe/codestral.git"
  },
  "bugs": {
    "url": "https://github.com/PetrJoe/codestral/issues"
  },
  "homepage": "https://github.com/PetrJoe/codestral#readme"
}